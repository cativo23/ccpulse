{
  "name": "lumira",
  "version": "0.8.0",
  "description": "Real-time statusline HUD for Claude Code and Qwen Code — context bar, burn rate, themes, powerline, zero deps.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lumira": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "themes:validate": "npm run build && node scripts/validate-themes.mjs",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/cativo23/lumira#readme",
  "bugs": {
    "url": "https://github.com/cativo23/lumira/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cativo23/lumira.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "qwen-code",
    "qwen",
    "statusline",
    "terminal",
    "nerd-font",
    "hud",
    "metrics",
    "pulse"
  ],
  "files": [
    "dist",
    "skills"
  ]
}
